{
  "expo": {
    "name": "CoinFox",
    "slug": "coinfox-mobile",
    "scheme": "coinfox",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easternpineventures.coinfox"
    },
    "android": {
      "package": "com.easternpineventures.coinfox"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "d68b5978-a125-4de8-bb8d-f4e1653ff69c"
      }
    }
  }
}
