# coinfox API keys — keep this file private, never commit it
# Copy .env.example to .env and fill in your keys.

# ── Free AI Providers ─────────────────────────────────────────────────────────

# HuggingFace Inference API  (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Groq  (https://console.groq.com/keys)
GROQ_API_KEY=

# Google Gemini  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenRouter free models  (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Mistral  (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=

# GitHub Models  (your GitHub PAT with model:read scope)
GITHUB_TOKEN=

# Together AI  (https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=

# Cloudflare Workers AI  (https://dash.cloudflare.com/profile/api-tokens)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# DeepInfra  (https://deepinfra.com/dash/api_keys)
DEEPINFRA_API_KEY=

# Perplexity  (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# Cohere  (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=

# Cerebras  (https://cloud.cerebras.ai)
CEREBRAS_API_KEY=

# Codex Pro / OpenAI-compatible  (set CODEX_BASE_URL to point at any compatible endpoint)
CODEX_API_KEY=

# ── Local AI ──────────────────────────────────────────────────────────────────

# Ollama model to use (must be pulled locally — run: ollama pull qwen3:8b)
COINFOX_OLLAMA_MODEL=

# ── On-chain data (optional) ───────────────────────────────────────────────────

# Ethereum JSON-RPC endpoint for the Chainlink on-chain price cross-check.
# OPTIONAL: CoinFox falls back to a keyless public RPC if this is unset. Set your
# own (e.g. an Alchemy/Infura URL) for higher reliability and rate limits.
COINFOX_ETH_RPC_URL=

# ── Misc ──────────────────────────────────────────────────────────────────────

# GitHub token for pushing coinfox itself (classic PAT, repo scope)
GH_TOKEN=
